# Hugging Face Inference API (Inference Providers)
# Token: https://huggingface.co/settings/tokens (permission: Inference Providers)
# Enable providers: https://huggingface.co/settings/inference-providers
HUGGINGFACE_API_TOKEN=hf_your_token_here

# Chat model on the HF router (must be supported by an enabled provider)
HF_MODEL_ID=meta-llama/Llama-3.1-8B-Instruct

# Embedding model for RAG (HF Inference API feature extraction)
HF_EMBEDDING_MODEL_ID=BAAI/bge-small-en-v1.5

# Streamlit UI -> FastAPI
# Local: http://localhost:8000
# Docker compose: http://api:8000
# Streamlit Cloud secret:
# API_URL=https://research-workflow-agent-production.up.railway.app
